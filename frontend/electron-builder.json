{
    "appId": "com.jalsetu.desktop",
    "productName": "Jalsetu",
    "directories": {
        "output": "release"
    },
    "files": [
        "dist/**/*",
        "electron/**/*",
        "package.json"
    ],
    "win": {
        "target": [
            "nsis"
        ],
        "icon": "public/icon.png"
    },
    "mac": {
        "target": [
            "dmg"
        ],
        "icon": "public/icon.png"
    },
    "linux": {
        "target": [
            "AppImage"
        ],
        "icon": "public/icon.png"
    }
}